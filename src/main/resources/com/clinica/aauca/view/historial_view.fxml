<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 30; -fx-background-color: white;" fx:controller="com.clinica.aauca.controller.HistorialController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="📖 Historial Médico del Paciente" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #003366;"/>
    <Separator />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="ID Paciente:" style="-fx-font-weight: bold;" />
        <TextField fx:id="txtPacienteId" promptText="Ej: 1" prefWidth="100" />
        <Button text="🔍 Cargar Historial" onAction="#cargarHistorial" styleClass="button btn-orange" />
        <Button text="🖨 Exportar Historial PDF" onAction="#exportarHistorialPDF" styleClass="button btn-green" />
        <Label fx:id="lblNombrePaciente" text="— Sin buscar —" style="-fx-text-fill: gray; -fx-font-style: italic;" />
    </HBox>

    <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS">
        <!-- Tab Consultas -->
        <Tab text="🩺 Consultas" closable="false">
            <TableView fx:id="tablaConsultasH" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colHFecha" text="Fecha" prefWidth="130" />
                    <TableColumn fx:id="colHReceta" text="Diagnóstico / Receta" prefWidth="350" />
                    <TableColumn fx:id="colHFactura" text="Monto (FCFA)" prefWidth="120" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </Tab>
        <!-- Tab Hospitalizaciones -->
        <Tab text="🏥 Hospitalizaciones" closable="false">
            <TableView fx:id="tablaHospH" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colHEstado" text="Estado" prefWidth="180" />
                    <TableColumn fx:id="colHSeguimiento" text="Seguimiento Clínico" prefWidth="420" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </Tab>
        <!-- Tab Resumen -->
        <Tab text="📊 Resumen" closable="false">
            <VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #F8F9FA;" alignment="CENTER">
                <Label fx:id="lblResumenNombre" text="Nombre:" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <HBox spacing="30" alignment="CENTER">
                    <VBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 4);" prefWidth="180">
                        <Label text="Total Consultas" style="-fx-text-fill: gray;" />
                        <Label fx:id="lblTotalConsultas" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #003366;" />
                    </VBox>
                    <VBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 4);" prefWidth="180">
                        <Label text="Hospitalizaciones" style="-fx-text-fill: gray;" />
                        <Label fx:id="lblTotalHosp" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" />
                    </VBox>
                    <VBox alignment="CENTER" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 4);" prefWidth="180">
                        <Label text="Total Facturado (FCFA)" style="-fx-text-fill: gray;" />
                        <Label fx:id="lblTotalFacturado" text="0 FCFA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" />
                    </VBox>
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
