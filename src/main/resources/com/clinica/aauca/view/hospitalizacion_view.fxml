<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 30; -fx-background-color: white;" fx:controller="com.clinica.aauca.controller.HospitalizacionController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="🏥 Seguimiento de Hospitalización" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #003366;"/>
    <Separator />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="HC Paciente:" style="-fx-font-weight: bold;" />
        <TextField fx:id="txtPacienteId" promptText="ID / HC" prefWidth="100" />
        <Button text="🔍 Buscar Internamiento" onAction="#buscarInternamiento" styleClass="button btn-orange" />
        <Label fx:id="lblNombrePaciente" text="— Sin buscar —" style="-fx-text-fill: gray; -fx-font-style: italic;" />
    </HBox>

    <!-- Historial de hospitalizaciones -->
    <Label text="Historial de Ingresos:" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
    <TableView fx:id="tablaHospitalizaciones" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colHospId" text="ID" prefWidth="40" />
            <TableColumn fx:id="colNombrePaciente" text="Paciente" prefWidth="150" />
            <TableColumn fx:id="colFechaTabla" text="Fecha Ingreso" prefWidth="100" />
            <TableColumn fx:id="colEstadoTabla" text="Estado" prefWidth="100" />
            <TableColumn fx:id="colMotivoTabla" text="Motivo" prefWidth="150" />
            <TableColumn fx:id="colSeguimientoTabla" text="Seguimiento Clínico" prefWidth="250" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <Separator />
    <Label text="Registrar / Actualizar Evolución:" style="-fx-font-weight: bold; -fx-font-size: 14px;" />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Estado General:" style="-fx-min-width: 120;" />
        <ComboBox fx:id="comboEstado" prefWidth="200" />
        <Label text="Motivo:" style="-fx-min-width: 80;" />
        <TextField fx:id="txtMotivo" promptText="Motivo del ingreso..." prefWidth="300" />
    </HBox>

    <Label text="Evolución / Seguimiento Clínico:" />
    <TextArea fx:id="txtSeguimiento" prefRowCount="4" promptText="Describa la evolución actual del paciente..." />

    <HBox spacing="10">
        <Button text="💾 Guardar Evolución" styleClass="button btn-green" onAction="#actualizarEvolucion" prefWidth="180" />
        <Button fx:id="btnNuevoIngreso" text="➕ Nuevo Ingreso" styleClass="button btn-orange" onAction="#nuevoIngreso" prefWidth="180" />
        <Button text="🖨 Imprimir Reporte" styleClass="button btn-blue" onAction="#imprimirReporteHosp" prefWidth="180" />
        <Button text="🗑 Eliminar" styleClass="button btn-red" onAction="#eliminarHospitalizacion" prefWidth="150" />
    </HBox>
</VBox>
