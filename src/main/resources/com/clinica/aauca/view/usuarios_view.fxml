<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 30; -fx-background-color: white;" fx:controller="com.clinica.aauca.controller.UsuariosController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="👥 Gestión de Usuarios del Sistema" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #003366;"/>
    <Separator />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtBuscarUsuario" promptText="Buscar por nombre o username..." prefWidth="300" />
        <Button text="🔍 Buscar" onAction="#buscarUsuario" styleClass="button btn-orange" />
        <Button text="↺ Ver Todos" onAction="#verTodos" styleClass="button" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="➕ Nuevo Usuario" onAction="#nuevoUsuario" styleClass="button btn-green" />
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Tabla de Usuarios -->
        <TableView fx:id="tablaUsuarios" HBox.hgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colUserId" text="ID" prefWidth="50" />
                <TableColumn fx:id="colUserUsername" text="Usuario" prefWidth="120" />
                <TableColumn fx:id="colUserNombre" text="Nombre Completo" prefWidth="200" />
                <TableColumn fx:id="colUserRol" text="Rol" prefWidth="100" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <!-- Formulario de Edición -->
        <VBox spacing="12" prefWidth="300" style="-fx-padding: 15; -fx-background-color: #F8F9FA; -fx-background-radius: 10;">
            <Label text="Editar Usuario Seleccionado" style="-fx-font-weight: bold; -fx-text-fill: #003366;" />
            <Separator />
            
            <Label text="Username:" />
            <TextField fx:id="txtUsername" />
            
            <Label text="Nombre Completo:" />
            <TextField fx:id="txtNombreCompleto" />
            
            <Label text="Rol:" />
            <ComboBox fx:id="cmbRol" prefWidth="270" />
            
            <Label text="Nueva Contraseña (opcional):" />
            <PasswordField fx:id="txtNewPass" promptText="Dejar vacío para no cambiar" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button text="💾 Guardar Cambios" onAction="#actualizarUsuario" maxWidth="Infinity" styleClass="button btn-blue" />
            <Button text="🗑 Eliminar Usuario" onAction="#eliminarUsuario" maxWidth="Infinity" styleClass="button btn-red" />
        </VBox>
    </HBox>

    <Separator />
</VBox>
