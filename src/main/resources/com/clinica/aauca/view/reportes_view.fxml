<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: white;" fx:controller="com.clinica.aauca.controller.ReportesController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="📊 Reportes Clínicos" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #003366;"/>
    <Separator />

    <!-- Cards estadísticas -->
    <HBox spacing="20" alignment="CENTER">
        <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #E3F2FD; -fx-padding: 20; -fx-background-radius: 12;" prefWidth="200">
            <Label text="👥 Total Pacientes" style="-fx-font-weight: bold; -fx-text-fill: #1565C0;" />
            <Label fx:id="lblTotalPacientes" text="0" style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #003366;" />
        </VBox>
        <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #E8F5E9; -fx-padding: 20; -fx-background-radius: 12;" prefWidth="200">
            <Label text="🩺 Total Consultas" style="-fx-font-weight: bold; -fx-text-fill: #2E7D32;" />
            <Label fx:id="lblTotalConsultas" text="0" style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" />
        </VBox>
        <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #FFF3E0; -fx-padding: 20; -fx-background-radius: 12;" prefWidth="200">
            <Label text="🏥 Hospitalizaciones" style="-fx-font-weight: bold; -fx-text-fill: #E65100;" />
            <Label fx:id="lblTotalHosp" text="0" style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" />
        </VBox>
        <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #FCE4EC; -fx-padding: 20; -fx-background-radius: 12;" prefWidth="200">
            <Label text="💊 Medicamentos" style="-fx-font-weight: bold; -fx-text-fill: #880E4F;" />
            <Label fx:id="lblTotalMed" text="0" style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
        </VBox>
        <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #F3E5F5; -fx-padding: 20; -fx-background-radius: 12;" prefWidth="200">
            <Label text="💰 Facturación Total (FCFA)" style="-fx-font-weight: bold; -fx-text-fill: #6A1B9A;" />
            <Label fx:id="lblTotalIngresos" text="0 FCFA" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8e44ad;" />
        </VBox>
    </HBox>

    <Separator />
    <Label text="Pacientes Más Frecuentes (Top 5):" style="-fx-font-weight: bold; -fx-font-size: 14px;" />

    <TableView fx:id="tablaTopPacientes" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colRpNombre" text="Paciente" prefWidth="300" />
            <TableColumn fx:id="colRpConsultas" text="N° Consultas" prefWidth="150" />
            <TableColumn fx:id="colRpHosp" text="N° Ingresos" prefWidth="150" />
            <TableColumn fx:id="colRpTotal" text="Total Facturado (FCFA)" prefWidth="200" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="📥 Exportar Resumen PDF" onAction="#exportarPDF" styleClass="button btn-blue" prefWidth="220" />
        <Button text="🔄 Actualizar Estadísticas" onAction="#actualizarEstadisticas" styleClass="button btn-orange" prefWidth="220" />
    </HBox>
</VBox>
