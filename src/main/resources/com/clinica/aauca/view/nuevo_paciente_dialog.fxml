<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="20" style="-fx-background-color: #F8FAFC; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.clinica.aauca.controller.NuevoPacienteDialogController">
    <!-- Main Content Container with Shadow -->
    <HBox spacing="40" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 20, 0, 0, 8);">
        
        <!-- Left Column: Patient Data -->
        <VBox spacing="25" HBox.hgrow="ALWAYS">
            <Label text="DATOS DEL PACIENTE" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-border-color: #3B82F6; -fx-border-width: 0 0 3 0; -fx-padding: 0 0 10 0;"/>
            
            <GridPane hgap="25" vgap="18">
                <columnConstraints>
                    <ColumnConstraints minWidth="110" prefWidth="130" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                
                <Label text="Nombres:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtNombres" promptText="Ingrese los nombres" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Apellidos:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtApellidos" promptText="Ingrese los apellidos" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Tipo:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <ComboBox fx:id="comboTipo" promptText="Seleccione Tipo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-padding: 5; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Sexo:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <ComboBox fx:id="comboSexo" promptText="Seleccione Sexo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-padding: 5; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="F. Nacimiento:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <DatePicker fx:id="dpFechaNacimiento" promptText="Seleccione Fecha" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-padding: 5; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Dirección:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtDireccion" promptText="Residencia actual" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Teléfono:" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtTelefono" promptText="Número de contacto" GridPane.columnIndex="1" GridPane.rowIndex="6" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Nacionalidad:" GridPane.columnIndex="0" GridPane.rowIndex="7" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtNacionalidad" promptText="Nacionalidad" GridPane.columnIndex="1" GridPane.rowIndex="7" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
            </GridPane>
        </VBox>
        
        <Separator orientation="VERTICAL" style="-fx-padding: 0 15;"/>
        
        <!-- Right Column: Triage / Vitals -->
        <VBox spacing="25" HBox.hgrow="ALWAYS">
            <Label text="SIGNOS VITALES (Triaje)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-border-color: #10B981; -fx-border-width: 0 0 3 0; -fx-padding: 0 0 10 0;"/>
            
            <GridPane hgap="25" vgap="18">
                <columnConstraints>
                    <ColumnConstraints minWidth="130" prefWidth="150" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                
                <Label text="Peso (kg):" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtPeso" promptText="Ej: 70.5" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Talla (cm):" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtTalla" promptText="Ej: 175" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Temperatura (°C):" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtTemperatura" promptText="Ej: 36.5" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Frec. Cardíaca:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtPulso" promptText="bpm" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Frec. Respiratoria:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtResp" promptText="rpm" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
                
                <Label text="Presión Arterial:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                <TextField fx:id="txtPresion" promptText="Ej: 120/80" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-font-size: 13px;" />
            </GridPane>
        </VBox>
        
    </HBox>
</VBox>
