<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: white;" fx:controller="com.clinica.aauca.controller.PagosController" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <Label text="💰 Pagos y Facturas (FCFA)" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #003366;"/>
    <Separator />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="ID Paciente:" style="-fx-font-weight: bold;" />
        <TextField fx:id="txtFiltroId" promptText="Filtrar por ID..." prefWidth="120" />
        <Button text="🔍 Filtrar" onAction="#filtrarPorPaciente" styleClass="button btn-orange" />
        <Button text="↺ Ver Todos" onAction="#verTodas" styleClass="button" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="Total Seleccionado:" style="-fx-font-weight: bold;" />
        <Label fx:id="lblTotalPago" text="0 FCFA" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #003366;" />
    </HBox>

    <TableView fx:id="tablaFacturas" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colFId" text="N° Factura" prefWidth="90" />
            <TableColumn fx:id="colFPaciente" text="Paciente" prefWidth="250" />
            <TableColumn fx:id="colFFecha" text="Fecha" prefWidth="120" />
            <TableColumn fx:id="colFReceta" text="Concepto" prefWidth="250" />
            <TableColumn fx:id="colFMonto" text="Monto (FCFA)" prefWidth="130" />
            <TableColumn fx:id="colFEstado" text="Estado" prefWidth="100" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Resumen financiero -->
    <HBox spacing="20" style="-fx-padding: 15; -fx-background-color: #F0F4F8; -fx-background-radius: 10;">
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="Total Cobrado (FCFA)" style="-fx-text-fill: gray; -fx-font-size: 12px;" />
            <Label fx:id="lblSumaCobrado" text="0 FCFA" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" />
        </VBox>
        <Separator orientation="VERTICAL" />
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="Exentos (Estudiantes)" style="-fx-text-fill: gray; -fx-font-size: 12px;" />
            <Label fx:id="lblSumaExento" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1976D2;" />
        </VBox>
        <Separator orientation="VERTICAL" />
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
            <Label text="Total Registros" style="-fx-text-fill: gray; -fx-font-size: 12px;" />
            <Label fx:id="lblTotalRegistros" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" />
        </VBox>
    </HBox>

    <HBox spacing="10">
        <Button text="🔄 Actualizar" onAction="#verTodas" styleClass="button btn-orange" prefWidth="200" />
        <Button text="🖨 Imprimir Ticket" onAction="#imprimirTicket" styleClass="button btn-green" prefWidth="200" />
        <Button text="🗑 Eliminar Seleccionado" onAction="#eliminarFactura" styleClass="button btn-red" prefWidth="200" />
    </HBox>
</VBox>
